{
  "name": "tagpulse-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test",
    "generate-api": "openapi --input ../TagPulse/openapi.json --output src/api/generated --client fetch",
    "generate-api:live": "openapi --input http://localhost:8000/openapi.json --output src/api/generated --client fetch",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5",
    "@microsoft/applicationinsights-react-js": "^19.4.0",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@tanstack/react-query": "^5.60",
    "@types/react-grid-layout": "^1.3.6",
    "antd": "^5.22",
    "dayjs": "^1.11.20",
    "leaflet": "^1.9.4",
    "react": "^19.0",
    "react-dom": "^19.0",
    "react-grid-layout": "^1.5",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.0",
    "recharts": "^2.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6",
    "@testing-library/react": "^16.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.0",
    "@types/react-dom": "^19.0",
    "@typescript-eslint/eslint-plugin": "^8.16",
    "@typescript-eslint/parser": "^8.16",
    "@vitejs/plugin-react": "^4.3",
    "eslint": "^9.15",
    "eslint-plugin-react-hooks": "^5.0",
    "eslint-plugin-react-refresh": "^0.4",
    "jsdom": "^25.0",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "^3.4",
    "typescript": "^5.7",
    "vite": "^6.0",
    "vitest": "^2.1"
  }
}
