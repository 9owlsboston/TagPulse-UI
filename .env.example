# Build-time configuration consumed by Vite (`import.meta.env.*`).
# These values are baked into the static bundle at `npm run build` time —
# they are NOT secrets and are visible to anyone who downloads the SPA.
#
# Real secrets (e.g. the Static Web Apps deployment token) live only in
# CI as GitHub Environment secrets. See scripts/ui-cicd-setup.sh.

# Base URL of the TagPulse API. Leave empty in local dev to use the Vite
# proxy (vite.config.ts) which forwards to http://localhost:8000.
# In deployed environments this must be the full https origin of the api,
# e.g. https://tpdev-api.<random>.<region>.azurecontainerapps.io
VITE_API_BASE_URL=
