root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[Makefile]
indent_style = tab

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{ps1,psm1,cmd,bat}]
end_of_line = crlf

[*.{py}]
indent_size = 4

[*.{go}]
indent_style = tab
